model AiShadowRun {
  id                String           @id @default(uuid())
  conversationId    String
  incomingMessageId String?          @unique
  unit              String
  instanceId        String
  contactId         String?
  contactPhone      String?
  contactName       String?
  status            String           @default("pending")
  triggerReason     String?
  promptVersion     String
  knowledgeVersion  String
  context           Json?
  error             String?
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  drafts            AiShadowDraft[]
  reviews           AiShadowReview[]

  @@index([unit])
  @@index([instanceId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
}

model AiShadowDraft {
  id               String      @id @default(uuid())
  runId            String
  modelKey         String
  blindLabel       String?
  provider         String
  model            String
  status           String      @default("pending")
  decision         String?
  messages         Json?
  handoffReason    String?
  confidence       Float?
  guardrailFlags   Json?
  rawText          String?
  error            String?
  latencyMs        Int?
  promptTokens     Int?
  completionTokens Int?
  costUsd          Float?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  run              AiShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, modelKey])
  @@index([runId])
  @@index([status])
  @@index([provider, model])
