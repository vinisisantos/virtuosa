  clientDesire    String
  status          String                @default("novo")
  resolutionNotes String?
  createdBy       String?
  createdByName   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  conclusionText  String?
  attachments     ComplaintAttachment[]
  history         ComplaintHistory[]

  @@index([unit])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ComplaintHistory {
  id          String    @id @default(uuid())
  complaintId String
  action      String
  notes       String
  actorId     String?
  actorName   String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([createdAt])
}

model ComplaintAttachment {
  id             String    @id @default(uuid())
  complaintId    String
  fileName       String
  mimeType       String
  fileData       Bytes
  uploadedBy     String?
  uploadedByName String?
  createdAt      DateTime  @default(now())
  complaint      Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model Atendimento {
  id               String         @id @default(uuid())
  clientId         String
  clientName       String
  profissionalId   String?
  profissionalName String?
  unit             String
  status           String         @default("rascunho")
  timerSeconds     Int            @default(0)
  privacidade      String         @default("privado")
  createdById      String?
  createdByName    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  fichaCorporal    FichaCorporal?
}

model FichaCorporal {
  id                   String      @id @default(uuid())
  atendimentoId        String      @unique
  distribuicaoGordura  String?
  peso                 Float?
  altura               Float?
  imc                  Float?
  adipometriaProtocolo String?
  adipometriaData      Json?
  percentualGordura    Float?
  perimetriaData       Json?
  grauCelulite         Int?
  tipoEstria           String?
  observacoesEstria    String?
  diasteseResultado    String?
  diasteseTipo         String?
  observacoesDiastese  String?
  aparenciaPercebida   Int?
  aparenciaDesejada    Int?
  observacoes          String?
