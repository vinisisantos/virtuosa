model Aparelho {
  id        String             @id @default(uuid())
  name      String
  color     String             @default("#3b82f6")
  createdAt DateTime           @default(now())
  alocacoes AlocacaoAparelho[]
}

model AlocacaoAparelho {
  id         String   @id @default(uuid())
  aparelhoId String
  unit       String
  date       DateTime @db.Date
  notes      String?
  createdAt  DateTime @default(now())
  userId     String?
  userName   String?
  aparelho   Aparelho @relation(fields: [aparelhoId], references: [id], onDelete: Cascade)

  @@unique([aparelhoId, date])
}

model DocTemplate {
  id          String         @id @default(uuid())
  name        String
  category    String
  description String?
  fields      Json
  unit        String?
  createdBy   String
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  fileData    String
  fileType    String         @default("pdf")
  documents   DocGenerated[]
}

model DocGenerated {
  id            String      @id @default(uuid())
  templateId    String
  templateName  String
  filledData    Json
  unit          String
  createdBy     String
  createdByName String
  createdAt     DateTime    @default(now())
  fileData      String?
  template      DocTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WhatsAppInstance {
  id            String                 @id @default(uuid())
  instanceId    String                 @unique
  name          String
  status        String                 @default("disconnected")
  token         String
  qrcode        String?
  unit          String?
  capturesLeads Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  phoneNumber   String?
  userId        String?
  conversations WhatsAppConversation[]
  user          User?                  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([unit])
  @@index([userId, unit, status])
  @@index([status])
}

model WhatsAppContact {
  id            String                 @id @default(uuid())
  phone         String                 @unique
  name          String?
  profilePic    String?
  unit          String?
  tags          Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  conversations WhatsAppConversation[]
}

model WhatsAppConversation {
  id                String            @id @default(uuid())
  instanceId        String
  contactId         String
  status            String            @default("open")
  assignedTo        String?
  unreadCount       Int               @default(0)
  lastMessage       String?
  lastMessageAt     DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignedToName    String?
  closeNote         String?
  closedAt          DateTime?
  closedBy          String?
  closedByName      String?
  reopenCount       Int               @default(0)
  reopenedAt        DateTime?
  resolution        String?
  satisfactionNote  String?
  satisfactionScore Int?
  contact           WhatsAppContact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  instance          WhatsAppInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  messages          WhatsAppMessage[]

  @@unique([contactId, instanceId])
  @@index([instanceId])
  @@index([instanceId, status, lastMessageAt])
  @@index([instanceId, lastMessageAt])
  @@index([assignedTo])
  @@index([status])
  @@index([unreadCount])
}

model WhatsAppMessage {
  id              String               @id @default(uuid())
  conversationId  String
  // messageId do WhatsApp é o MESMO para remetente e destinatário — quando
  // dois números conectados no CRM conversam entre si, a unicidade global
  // impedia a gravação da mensagem na segunda caixa (só o preview atualizava).
  // Por isso a unicidade é por conversa.
  messageId       String
  body            String
  type            String               @default("text")
  mediaUrl        String?
  fromMe          Boolean              @default(false)
  status          String               @default("sent")
  timestamp       DateTime
  createdAt       DateTime             @default(now())
  respondedBy     String?
  respondedByName String?
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId, timestamp])
  @@index([timestamp])
}

model CrmSilentAnalysisSetting {
