generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PayrollImport {
  id               String         @id @default(cuid())
  fileName         String
  competenceMonth  Int
  competenceYear   Int
  unit             String         @default("Barueri")
  uploadDate       DateTime       @default(now())
  processingStatus String         @default("processing")
  rawExtractedText String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  entries          PayrollEntry[]

  @@unique([competenceMonth, competenceYear, unit])
}

model PayrollEntry {
  id               String        @id @default(uuid())
  payrollImportId  String
  employeeName     String
  netSalary        Float
  paymentStatus    String        @default("unpaid")
  paymentDate      DateTime?
  confidenceScore  Float         @default(1.0)
  extractionSource String?
  hasPenalty       Boolean       @default(false)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  baseSalary       Float?
  bonus            Float?        @default(0)
  cargo            String?
  hasAdiantamento  Boolean       @default(false)
  isRecurring      Boolean       @default(false)
  hasFgts          Boolean       @default(true)
  payrollImport    PayrollImport @relation(fields: [payrollImportId], references: [id], onDelete: Cascade)
}

model Order {
  id               String    @id @default(uuid())
  productName      String
  quantity         Int
  urgency          String
  status           String    @default("Aguardando")
  unit             String?   @default("Barueri")
  notes            String?
  unitPrice        Float?
  totalPrice       Float?
  sourceUrl        String?
  batchNumber      Int?
  estimatedArrival DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([batchNumber])
  @@index([status])
}

model OrderApproval {
  id             String    @id @default(uuid())
  orderId        String
  requesterId    String?
  requesterName  String
  changeType     String
  changeData     String
  description    String
  reason         String?
  status         String    @default("pendente")
  reviewedBy     String?
  reviewedByName String?
  reviewedAt     DateTime?
  unit           String?   @default("Barueri")
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([orderId])
  @@index([createdAt])
  @@index([unit])
}

model OrderAuditLog {
  id            String    @id @default(uuid())
  orderId       String
  approvalId    String?
  action        String
  field         String?
  oldValue      String?
  newValue      String?
  reason        String?
  actorId       String?
  actorName     String
  approverId    String?
  approverName  String?
  productName   String
  batchNumber   Int?
  unit          String?
  createdAt     DateTime  @default(now())
  isDeleted     Boolean   @default(false)
  deletedBy     String?
  deletedByName String?
  deletedAt     DateTime?

  @@index([orderId])
  @@index([action])
  @@index([createdAt])
  @@index([actorId])
  @@index([isDeleted])
}

model User {
  id                String             @id @default(uuid())
  name              String
  phone             String?
  email             String             @unique
  password          String
  role              String             @default("VENDEDOR")
  unit              String?            @default("Barueri")
  permissions       Json?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  whatsappInstances WhatsAppInstance[]
  clients           Client[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  userName  String?
  createdAt DateTime @default(now())
}

model InsumoUpload {
  id            String   @id @default(uuid())
  fileName      String
  fileType      String
  fileSize      Int
  prompt        String
  extractedData String?
  status        String   @default("processing")
  errorMessage  String?
  unit          String?  @default("Barueri")
  userId        String?
  userName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MercadoLivreConnection {
  id           String              @id @default(uuid())
  unit         String              @unique
  mlUserId     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  mlUsername   String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  orders       MercadoLivreOrder[]
}

model MercadoLivreOrder {
  id              String                 @id @default(uuid())
  mlOrderId       String                 @unique
  connectionId    String
  unit            String
  productTitle    String
  productImageUrl String?
  quantity        Int                    @default(1)
  totalAmount     Float
  currencyId      String                 @default("BRL")
  orderStatus     String
  shippingStatus  String?
  trackingNumber  String?
  trackingUrl     String?
  sellerNickname  String?
  buyDate         DateTime
  lastUpdated     DateTime
  rawData         String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  connection      MercadoLivreConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model Adiantamento {
  id          String    @id @default(uuid())
  description String
  value       Float
  recipient   String
  unit        String    @default("Barueri")
  status      String    @default("pendente")
  isRecurring Boolean   @default(false)
  notes       String?
  finalizedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FinancialBackup {
  id        String   @id @default(uuid())
  userId    String?
  logs      String
  goals     String
  fixed     String
  bills     String
  isAuto    Boolean  @default(true)
  unit      String   @default("Barueri")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unit])
}

model CancelamentoHistory {
  id              String   @id @default(uuid())
  clientName      String
  unit            String   @default("Barueri")
  scenario        String
  totalPago       Float
  totalConsumido  Float
  multa           Float
  totalDevolver   Float
  proceduresCount Int
  createdAt       DateTime @default(now())
  html            String?
}

model TermoHistory {
  id           String   @id @default(uuid())
  templateName String
  clientName   String
  unit         String   @default("Barueri")
  docType      String
  html         String
  createdAt    DateTime @default(now())
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeName String
  unit         String
  fileName     String
  fileType     String
  fileSize     Int
  fileData     String
  createdAt    DateTime @default(now())

  @@index([employeeName, unit])
}

model ProcedimentoTermo {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Profissional {
  id              String        @id @default(uuid())
  name            String
  unit            String        @default("Barueri")
  color           String        @default("#e600a0")
  isActive        Boolean       @default(true)
  absenceSchedule Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  agendamentos    Agendamento[]
}

model Agendamento {
  id             String       @id @default(uuid())
  clientName     String
  clientPhone    String?
  procedimento   String
  profissionalId String
  unit           String       @default("Barueri")
  startTime      DateTime
  endTime        DateTime
  status         String       @default("pendente")
  sala           String?
  sessionNumber  Int?
  totalSessions  Int?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  profissional   Profissional @relation(fields: [profissionalId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  userName    String
  action      String
  entityType  String
  entityId    String?
  description String
  metadata    String?
  ipAddress   String?
  unit        String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entityType])
}

model Client {
  id            String    @id @default(uuid())
  name          String
  phone         String?
  email         String?
  cpf           String?
  rg            String?
  birthdate     String?
  gender        String?
  profissao     String?
  estadoCivil   String?
  unit          String    @default("Barueri")
  notes         String?
  tags          String?
  totalSpent    Float     @default(0)
  visitCount    Int       @default(0)
  lastVisit     DateTime?
  isActive      Boolean   @default(true)
  stage         String    @default("entrada")
  source        String?
  followUpDate  DateTime?
  packageValue  Float?
  cep           String?
  estado        String?
  cidade        String?
  bairro        String?
  rua           String?
  numero        String?
  complemento   String?
  pais          String?   @default("Brasil")
  quoteValue    Float?    @default(0)
  quoteData     String?
  paymentMethod String?
  installments  Int?      @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  closingDate   String?
  campaignId    String?
  campaignName  String?
  fbclid        String?
  utmCampaign   String?
  utmContent    String?
  utmMedium     String?
  utmSource     String?
  arrivedAt     DateTime?
  userId        String?
  user          User?             @relation(fields: [userId], references: [id])
  originUnit    String?
  @@index([name])
  @@index([unit])
  @@index([originUnit])
  @@index([phone])
  @@index([stage])
  @@index([source])
}

model Package {
  id                String   @id @default(uuid())
  clientName        String
  clientId          String?
  services          String
  totalValue        Float
  paidValue         Float    @default(0)
  paymentMethod     String   @default("pix")
  installments      Int      @default(1)
  totalSessions     Int      @default(1)
  completedSessions Int      @default(0)
  status            String   @default("ativo")
  unit              String   @default("Barueri")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientName])
  @@index([clientId])
  @@index([status])
  @@index([unit])
}

model TreatmentSession {
  id            String   @id @default(uuid())
  packageId     String
  sessionNumber Int
  date          DateTime @default(now())
  professional  String?
  needsPhotos   Boolean  @default(false)
  needsMeasures Boolean  @default(false)
  photos        String?
  measures      String?
  notes         String?
  status        String   @default("concluida")
  createdAt     DateTime @default(now())

  @@index([packageId])
  @@index([date])
}

model StockItem {
  id          String          @id @default(uuid())
  name        String
  category    String          @default("Produto")
  unit        String          @default("Barueri")
  quantity    Int             @default(0)
  minQuantity Int             @default(5)
  unitCost    Float           @default(0)
  supplier    String?
  location    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]

  @@index([unit])
  @@index([category])
}

model StockMovement {
  id          String    @id @default(uuid())
  stockItemId String
  type        String
  quantity    Int
  reason      String?
  userName    String?
  createdAt   DateTime  @default(now())
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  title     String
  message   String
  icon      String   @default("notifications")
  link      String?
  isRead    Boolean  @default(false)
  unit      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([unit])
}

model AuditLog {
  id        String   @id @default(uuid())
  userName  String
  action    String
  entity    String
  entityId  String   @default("")
  details   String
  unit      String?  @default("Barueri")
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@index([unit])
}

model Payment {
  id             String    @id @default(uuid())
  clientName     String
  description    String
  amount         Float
  method         String
  status         String    @default("pendente")
  installments   Int       @default(1)
  currentInstall Int       @default(1)
  dueDate        DateTime
  paidAt         DateTime?
  unit           String    @default("Barueri")
  agendamentoId  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([clientName])
  @@index([dueDate])
  @@index([unit])
}

model ClientPhoto {
  id           String   @id @default(uuid())
  clientId     String
  clientName   String
  type         String
  procedimento String
  imageData    String
  notes        String?
  unit         String?  @default("Barueri")
  sessionDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([clientId])
  @@index([type])
  @@index([unit])
}

model ServiceChecklist {
  id           String   @id @default(uuid())
  procedimento String   @unique
  items        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WaitlistEntry {
  id           String   @id @default(uuid())
  clientName   String
  clientPhone  String?
  procedimento String
  profissional String?
  desiredDate  DateTime
  unit         String   @default("Barueri")
  notes        String?
  status       String   @default("aguardando")
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([desiredDate])
  @@index([unit])
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  clientId    String
  clientName  String
  points      Int
  type        String
  reason      String
  description String?
  unit        String?  @default("Barueri")
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([type])
  @@index([unit])
}

model DigitalContract {
  id               String    @id @default(uuid())
  clientName       String
  clientCpf        String?
  clientEmail      String?
  templateName     String
  content          String
  pdfContent       String?
  status           String    @default("pendente")
  signingToken     String?   @unique
  signedAt         DateTime?
  signatureIp      String?
  signatureImage   String?
  assifanyDocId    String?
  assifanySignId   String?
  assifanyUrl      String?
  unit             String    @default("Barueri")
  createdAt        DateTime  @default(now())
  autentiqueDocId  String?
  autentiqueSignId String?
  signatureLink    String?
  signedPdfUrl     String?
  deliveryMethod   String?
  autentiqueStatus String?

  @@index([clientName])
  @@index([status])
  @@index([signingToken])
  @@index([assifanyDocId])
  @@index([autentiqueDocId])
}

model SatisfactionSurvey {
  id             String    @id @default(uuid())
  clientName     String
  clientPhone    String?
  score          Int
  feedback       String?
  procedimento   String?
  profissional   String?
  unit           String    @default("Barueri")
  createdAt      DateTime  @default(now())
  answeredAt     DateTime?
  conversationId String?
  sentAt         DateTime?
  status         String    @default("sent")
  profissionalId String?
  token          String?   @unique @default(uuid())

  @@index([token])
  @@index([score])
  @@index([unit])
  @@index([status])
  @@index([clientPhone])
  @@index([profissionalId])
}

model ServiceCatalog {
  id          String   @id @default(uuid())
  code        String?
  name        String
  description String?
  category    String   @default("Estética")
  price       Float
  cost        Float    @default(0)
  duration    Int      @default(60)
  unit        String   @default("Todas")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([active])
  @@index([code])
}

model CommunicationLog {
  id          String   @id @default(uuid())
  clientName  String
  clientPhone String?
  channel     String   @default("whatsapp")
  direction   String   @default("outgoing")
  message     String
  type        String   @default("manual")
  unit        String   @default("Barueri")
  createdAt   DateTime @default(now())

  @@index([clientName])
  @@index([channel])
  @@index([type])
}

model ReembolsoTicket {
  id               String                @id @default(uuid())
  ticketNumber     Int                   @unique @default(autoincrement())
  requesterId      String?
  requesterName    String
  unit             String                @default("Barueri")
  status           String                @default("pendente")
  totalAmount      Float                 @default(0)
  reimbursedAmount Float                 @default(0)
  isCreatedByAdmin Boolean               @default(false)
  adminNotes       String?
  reviewedBy       String?
  reviewedAt       DateTime?
  finalizedAt      DateTime?
  paymentProofData String?
  paymentProofName String?
  paymentProofType String?
  paidAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  alocacoes        AlocacaoReembolso[]
  attachments      ReembolsoAttachment[]
  items            ReembolsoItem[]

  @@index([status])
  @@index([unit])
  @@index([requesterId])
  @@index([isCreatedByAdmin])
  @@index([createdAt])
}

model ReembolsoItem {
  id           String          @id @default(uuid())
  ticketId     String
  name         String
  price        Float
  isReimbursed Boolean         @default(false)
  reimbursedAt DateTime?
  reimbursedBy String?
  description  String?
  expenseDate  DateTime?
  ticket       ReembolsoTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model ReembolsoAttachment {
  id        String          @id @default(uuid())
  ticketId  String
  fileName  String
  fileType  String
  fileSize  Int
  fileData  String
  createdAt DateTime        @default(now())
  ticket    ReembolsoTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model ReembolsoAuditLog {
  id          String   @id @default(uuid())
  ticketId    String
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  actorId     String?
  actorName   String
  description String?
  createdAt   DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

model RecebimentoReembolso {
  id                  String              @id @default(uuid())
  unit                String
  usuarioId           String
  valorRecebido       Float
  creditoAnterior     Float
  totalDisponivel     Float
  totalLiquidado      Float
  creditoGerado       Float
  quantidadeLiquidada Int
  createdAt           DateTime            @default(now())
  alocacoes           AlocacaoReembolso[]

  @@index([unit, createdAt])
}

model AlocacaoReembolso {
  id            String               @id @default(uuid())
  recebimentoId String
  ticketId      String
  valorAlocado  Float
  createdAt     DateTime             @default(now())
  recebimento   RecebimentoReembolso @relation(fields: [recebimentoId], references: [id], onDelete: Cascade)
  ticket        ReembolsoTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([recebimentoId, ticketId])
  @@index([recebimentoId])
  @@index([ticketId])
}

model CreditoAcumulado {
  id                String   @id @default(uuid())
  unit              String   @unique
  saldo             Float    @default(0)
  ultimaAtualizacao DateTime @updatedAt
}

model MetaConfig {
  id            String    @id @default(uuid())
  appId         String?
  appSecret     String?
  accessToken   String?
  verifyToken   String?
  pageId        String?
  phoneNumberId String?
  wabaId        String?
  unit          String    @unique @default("Barueri")
  isActive      Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestOk    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MetaLead {
  id           String    @id @default(uuid())
  leadgenId    String    @unique
  formId       String?
  formName     String?
  adId         String?
  adName       String?
  campaignId   String?
  campaignName String?
  pageId       String?
  platform     String    @default("facebook")
  name         String?
  email        String?
  phone        String?
  rawData      String?
  clientId     String?
  unit         String?   @default("Barueri")
  status       String    @default("novo")
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([clientId])
  @@index([createdAt])
  @@index([unit])
}

model SalesPipeline {
  id            String         @id @default(uuid())
  clientId      String
  clientName    String
  stage         String         @default("novo_lead")
  value         Float          @default(0)
  source        String?
  assignedTo    String?
  assignedName  String?
  unit          String         @default("Barueri")
  notes         String?
  leadId        String?
  lostReason    String?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pipelineId    String?
  stageId       String?
  pipeline      Pipeline?      @relation(fields: [pipelineId], references: [id])
  pipelineStage PipelineStage? @relation(fields: [stageId], references: [id])

  @@index([stage])
  @@index([clientId])
  @@index([assignedTo])
  @@index([unit])
  @@index([createdAt])
  @@index([pipelineId])
  @@index([stageId])
}

model LeadAssignment {
  id             String    @id @default(uuid())
  userId         String
  userName       String
  unit           String    @default("Barueri")
  isActive       Boolean   @default(true)
  weight         Int       @default(1)
  lastAssignedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([unit])
  @@index([isActive])
}

model WebhookLog {
  id           String    @id @default(uuid())
  source       String
  eventType    String
  payload      String?
  status       String    @default("received")
  errorMessage String?
  retryCount   Int       @default(0)
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model Campaign {
  id        String   @id @default(uuid())
  name      String
  platform  String   @default("meta_ads")
  status    String   @default("ativa")
  objective String?
  budget    Float?
  startDate String?
  endDate   String?
  unit      String   @default("Barueri")
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([unit])
  @@index([name])
}

model ContractTemplate {
  id                String   @id @default(uuid())
  name              String
  type              String   @default("Contrato de prestação de serviço")
  htmlContent       String
  fileName          String?
  fileBase64        String?
  backgroundPdf     String?
  backgroundPdfName String?
  active            Boolean  @default(true)
  isGlobal          Boolean  @default(true)
  unit              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([unit])
}

model PricingProtocol {
  id               String   @id @default(uuid())
  name             String
  unit             String   @default("Todas")
  aluguel          Float    @default(0)
  energiaEletrica  Float    @default(0)
  aguaInternet     Float    @default(0)
  contador         Float    @default(0)
  salarios         Float    @default(0)
  proLabore        Float    @default(0)
  materiaisGerais  Float    @default(0)
  marketingTrafego Float    @default(0)
  comissoes        Float    @default(0)
  taxasPlataformas Float    @default(0)
  outros           Float    @default(0)
  diasTrabalhados  Int      @default(26)
  horasDia         Int      @default(8)
  minutosDia       Int      @default(0)
  qtdSalas         Int      @default(1)
  impostos         Float    @default(8)
  taxaCartao       Float    @default(12)
  descontoPaciente Float    @default(10)
  lucroClinica     Float    @default(70)
  lucroParceiro    Float    @default(0)
  insumos          Json     @default("[]")
  duracaoHoras     Int      @default(1)
  duracaoMinutos   Int      @default(0)
  locacaoAparelho  Float    @default(0)
