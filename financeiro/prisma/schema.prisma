  @@index([status])
  @@index([triggerType])
}

model FlowRun {
  id            String    @id @default(uuid())
  flowId        String
  contactPhone  String?
  contactName   String?
  status        String    @default("active")
  currentNodeId String?
  vars          Json?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  endReason     String?
  flow          Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([status])
}

model Pipeline {
