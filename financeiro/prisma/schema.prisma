model AiShadowSetting {
  id                 String   @id @default(uuid())
  unit               String   @unique
  enabled            Boolean  @default(false)
  mode               String   @default("shadow")
  allowedInstanceIds Json?
  modelA             String   @default("gemini:gemini-2.5-flash")
  modelB             String   @default("openai:gpt-5.4")
  onlyAfterHours     Boolean  @default(true)
  timezone           String   @default("America/Sao_Paulo")
  weekdayStart       String   @default("19:00")
  weekdayEnd         String   @default("08:00")
  weekendEnabled     Boolean  @default(true)
  maxRunsPerDay      Int      @default(80)
