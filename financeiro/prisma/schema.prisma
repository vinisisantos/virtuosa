  salarioBase      Float    @default(0)
  temInsalubridade Boolean  @default(false)
  temRT            Boolean  @default(false)
  status           String   @default("ativo")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([unidade])
  @@index([status])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id              String                @id @default(uuid())
