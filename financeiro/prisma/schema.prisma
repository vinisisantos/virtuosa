  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  run                AiShadowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([reviewerId])
  @@index([createdAt])
}

model Flow {
